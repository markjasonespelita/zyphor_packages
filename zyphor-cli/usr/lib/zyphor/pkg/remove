#!/bin/bash

# ==================================================
# Zyphor pkg remove (registry-aware)
# ==================================================

REGISTRY_URL="https://markjasonespelita.github.io/zyphor_repo/registry/registry.json"
CACHE_FILE="/tmp/zyphor_registry.json"

zyphor_pkg_remove() {

  APP="$3"

  # ===== Validate input =====
  if [ -z "$APP" ]; then
    echo ""
    echo "Zyphor: ✖ Missing app name"
    echo "Usage: zyphor pkg remove <app>"
    echo ""
    return 1
  fi

  # ===== Root check =====
  if [ "$EUID" -ne 0 ]; then
    echo ""
    echo "Zyphor: ⚠ Requires root privileges"
    echo "Try: sudo zyphor pkg remove $APP"
    echo ""
    return 1
  fi

  # ==================================================
  # LOAD REGISTRY
  # ==================================================
  echo ""
  echo "Zyphor: Loading registry..."

  if ! curl -fsSL "$REGISTRY_URL" -o "$CACHE_FILE"; then
    echo "Zyphor: ⚠ Using cached registry..."

    if [ ! -f "$CACHE_FILE" ]; then
      echo "Zyphor: ✖ No registry available"
      return 1
    fi
  fi

  # ==================================================
  # RESOLVE APP
  # ==================================================
  TYPE=$(jq -r ".apps.\"$APP\".type" "$CACHE_FILE")
  PACKAGE=$(jq -r ".apps.\"$APP\".package" "$CACHE_FILE")
  REPO=$(jq -r ".apps.\"$APP\".repo" "$CACHE_FILE")
  MODULE=$(jq -r ".apps.\"$APP\".module" "$CACHE_FILE")

  # ===== Validate app exists =====
  if [ "$TYPE" = "null" ] || [ -z "$TYPE" ]; then
    echo ""
    echo "Zyphor: ✖ App not found → $APP"
    return 1
  fi

  # ==================================================
  # SAFETY CONFIRMATION
  # ==================================================
  echo ""
  echo "Zyphor: You are about to remove → $APP ($TYPE)"
  read -p "Continue? [y/N]: " CONFIRM

  case "$CONFIRM" in
    y|Y) ;;
    *)
      echo "Zyphor: Cancelled."
      echo ""
      return 0
      ;;
  esac

  # ==================================================
  # REMOVE ENGINE
  # ==================================================
  echo ""
  echo "Zyphor: Removing '$APP'..."
  echo ""

  case "$TYPE" in

    # --------------------------
    # APT / REPO APPS
    # --------------------------
    apt|repo)
      echo "Zyphor: Removing APT package → $PACKAGE"
      apt remove -y "$PACKAGE"
      ;;

    # --------------------------
    # SNAP APPS (NEW)
    # --------------------------
    snap)
      echo "Zyphor: Removing Snap package → $PACKAGE"

      if snap list 2>/dev/null | awk '{print $1}' | grep -qx "$PACKAGE"; then
        snap remove "$PACKAGE"
      else
        echo "Zyphor: ⚠ Snap package not installed → $PACKAGE"
      fi
      ;;

    # --------------------------
    # DEB INSTALLED APPS
    # --------------------------
    deb)
      echo "Zyphor: Removing DEB package → $PACKAGE"
      apt remove -y "$PACKAGE"
      ;;

    # --------------------------
    # INTERNAL MODULE
    # --------------------------
    internal)
      echo "Zyphor: Removing internal module → $MODULE"
      bash "/usr/lib/zyphor/modules/$MODULE/remove.sh"
      ;;

    *)
      echo "Zyphor: ✖ Unknown type → $TYPE"
      return 1
      ;;
  esac

  # ==================================================
  # CLEANUP OPTION
  # ==================================================
  echo ""
  read -p "Zyphor: Run autoremove (cleanup dependencies)? [y/N]: " AUTO

  if [[ "$AUTO" =~ ^[yY]$ ]]; then
    apt autoremove -y
    echo "Zyphor: ✔ Cleanup complete"
  fi

  echo ""
  echo "Zyphor: ✔ Successfully removed '$APP'"
  echo ""
}