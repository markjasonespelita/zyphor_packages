#!/bin/bash

# ==================================================
# Zyphor pkg search (registry-aware)
# Searches apps, not system packages
# ==================================================

REGISTRY_URL="https://markjasonespelita.github.io/zyphor_repo/registry/registry.json"
CACHE_FILE="/tmp/zyphor_registry.json"

zyphor_pkg_search() {

  KEYWORD="$3"

  # ===== Validate input =====
  if [ -z "$KEYWORD" ]; then
    echo ""
    echo "Zyphor: ✖ Missing search keyword"
    echo "Usage: zyphor pkg search <keyword>"
    echo ""
    return 1
  fi

  echo ""
  echo "Zyphor: Searching registry for '$KEYWORD'..."
  echo ""

  # ==================================================
  # FETCH REGISTRY
  # ==================================================
  if ! curl -fsSL "$REGISTRY_URL" -o "$CACHE_FILE"; then
    echo "Zyphor: ⚠ Failed to fetch registry"

    if [ ! -f "$CACHE_FILE" ]; then
      echo "Zyphor: ✖ No registry available"
      return 1
    fi

    echo "Zyphor: Using cached registry..."
  fi

  # ==================================================
  # SEARCH IN APPS
  # ==================================================
  MATCHES=$(jq -r '.apps | keys[]' "$CACHE_FILE" | grep -i "$KEYWORD")

  if [ -z "$MATCHES" ]; then
    echo "Zyphor: ⚠ No apps found for '$KEYWORD'"
    echo ""
    return 0
  fi

  # ==================================================
  # DISPLAY RESULTS
  # ==================================================
  echo "Results:"
  echo ""

  COUNT=0

  for app in $MATCHES; do

    TYPE=$(jq -r ".apps.\"$app\".type" "$CACHE_FILE")
    PACKAGE=$(jq -r ".apps.\"$app\".package" "$CACHE_FILE")

    printf " - %-20s [%s] → %s\n" "$app" "$TYPE" "$PACKAGE"

    COUNT=$((COUNT + 1))

  done

  echo ""
  echo "Zyphor: ✔ Found $COUNT app(s)"
  echo ""
}