zyphor_pkg_install() {

  APP="$3"

  # ===== Validate input =====
  if [ -z "$APP" ]; then
    echo ""
    echo "Zyphor: ✖ Missing app name"
    echo "Usage: zyphor pkg install <app>"
    echo ""
    return 1
  fi

  # ===== Root check =====
  if [ "$EUID" -ne 0 ]; then
    echo ""
    echo "Zyphor: ⚠ Requires root privileges"
    echo "Try: sudo zyphor pkg install $APP"
    echo ""
    return 1
  fi

  # ==================================================
  # FETCH REGISTRY
  # ==================================================
  echo ""
  echo "Zyphor: Fetching registry..."

  if ! curl -fsSL "$REGISTRY_URL" -o "$CACHE_FILE"; then
    echo "Zyphor: ⚠ Failed to fetch remote registry"

    if [ ! -f "$CACHE_FILE" ]; then
      echo "Zyphor: ✖ No local cache available"
      return 1
    fi

    echo "Zyphor: Using cached registry..."
  fi

  # ==================================================
  # RESOLVE APP
  # ==================================================
  TYPE=$(jq -r ".apps.\"$APP\".type" "$CACHE_FILE")
  PACKAGE=$(jq -r ".apps.\"$APP\".package" "$CACHE_FILE")
  REPO_KEY=$(jq -r ".apps.\"$APP\".repo" "$CACHE_FILE")
  MODULE=$(jq -r ".apps.\"$APP\".module" "$CACHE_FILE")
  URL=$(jq -r ".apps.\"$APP\".url" "$CACHE_FILE")

  # NEW: FLAGS + CHANNEL
  FLAGS=$(jq -r ".apps.\"$APP\".flags // empty" "$CACHE_FILE")
  CHANNEL=$(jq -r ".apps.\"$APP\".channel // empty" "$CACHE_FILE")

  # ===== Validate app =====
  if [ "$TYPE" = "null" ] || [ -z "$TYPE" ]; then
    echo ""
    echo "Zyphor: ✖ App not found → $APP"
    echo ""
    return 1
  fi

  echo ""
  echo "Zyphor: Installing '$APP' (type: $TYPE)"
  echo ""

  case "$TYPE" in

    # --------------------------
    # APT INSTALL (FLAGS SUPPORT)
    # --------------------------
    apt)
      echo "Zyphor: APT install → $PACKAGE"

      apt update -qq
      apt install $FLAGS "$PACKAGE"
      ;;

    # --------------------------
    # REPO INSTALL
    # --------------------------
    repo)
      echo "Zyphor: Repo install via → $REPO_KEY"

      REPO_KEY_URL=$(jq -r ".repos.\"$REPO_KEY\".key_url" "$CACHE_FILE")
      REPO_LINE=$(jq -r ".repos.\"$REPO_KEY\".repo_line" "$CACHE_FILE")
      REPO_FILE=$(jq -r ".repos.\"$REPO_KEY\".source_file" "$CACHE_FILE")

      if [ "$REPO_LINE" = "null" ] || [ -z "$REPO_LINE" ]; then
        echo "Zyphor: ✖ Repo not found → $REPO_KEY"
        return 1
      fi

      if [ "$REPO_KEY_URL" != "null" ] && [ -n "$REPO_KEY_URL" ]; then
        echo "Zyphor: Adding repo key..."
        wget -q -O - "$REPO_KEY_URL" | apt-key add -
      fi

      if [ -n "$REPO_FILE" ] && [ "$REPO_FILE" != "null" ]; then
        echo "Zyphor: Writing repo file → $REPO_FILE"
        echo "$REPO_LINE" > "$REPO_FILE"
      fi

      apt update -qq
      apt install $FLAGS "$PACKAGE"
      ;;

    # --------------------------
    # DEB INSTALL
    # --------------------------
    deb)
      echo "Zyphor: Downloading .deb → $URL"

      TMP_DEB="/tmp/zyphor_${APP}.deb"
      wget -q "$URL" -O "$TMP_DEB"

      dpkg -i $FLAGS "$TMP_DEB"
      apt -f install -y
      ;;

    # --------------------------
    # SNAP INSTALL (FLAGS + CHANNEL SUPPORT)
    # --------------------------
    snap)
      echo "Zyphor: Snap install → $PACKAGE"

      if ! command -v snap >/dev/null 2>&1; then
        echo "Zyphor: Installing snapd..."
        apt update -qq
        apt install -y snapd
      fi

      # DEFAULT CHANNEL
      if [ -z "$CHANNEL" ] || [ "$CHANNEL" = "null" ]; then
        CHANNEL="stable"
      fi

      echo "Zyphor: Channel → $CHANNEL"

      snap install "$PACKAGE" $FLAGS --channel="$CHANNEL"
      ;;

    # --------------------------
    # INTERNAL MODULE
    # --------------------------
    internal)
      echo "Zyphor: Running module → $MODULE"
      bash "/usr/lib/zyphor/modules/$MODULE/install.sh"
      ;;

    # --------------------------
    # UNKNOWN TYPE
    # --------------------------
    *)
      echo "Zyphor: ✖ Unknown type → $TYPE"
      return 1
      ;;
  esac

  # ==================================================
  # RESULT
  # ==================================================
  if [ $? -eq 0 ]; then
    echo ""
    echo "Zyphor: ✔ Installed '$APP' successfully"
    echo ""
  else
    echo ""
    echo "Zyphor: ✖ Failed installing '$APP'"
    echo ""
    return 1
  fi
}